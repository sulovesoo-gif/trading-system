-- 4. [변경 이력] 1분당 1행 기록 (이벤트 취합형)
CREATE TABLE IF NOT EXISTS signal_history (
    id SERIAL PRIMARY KEY,
    symbol VARCHAR(20) REFERENCES stock_master(symbol),
    current_price NUMERIC,
    profit_rate NUMERIC,
    trade_value BIGINT,
    volume BIGINT,
    scores INTEGER,
    -- 1분 단위로 새로 발생한 이벤트 시각만 기록 (기존 발생건은 NULL)
