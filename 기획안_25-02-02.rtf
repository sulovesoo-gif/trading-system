1. DB 설계 변경 (이력 관리 & 보유 종목)
말씀하신 대로 10분 단위 Snapshot 이력을 남기고, 100일이 지난 데이터는 자동으로 삭제(Purge)하는 구조로 설계하겠습니다.

SQL
-- [1] 통합 실시간 테이블 (현재 상태)
CREATE TABLE IF NOT EXISTS detected_signals (
    symbol TEXT PRIMARY KEY,
    stock_name TEXT,
    current_price NUMERIC,
    profit_rate NUMERIC,
    trade_value BIGINT,        -- 거래대금
    volume BIGINT,             -- 거래량
    vol_diff BIGINT,           -- 전일 대비 거래량 차이
    high_5d NUMERIC,           -- 5일 신고가 (달성 시 가격, 미달 시 NULL)
    bb_status TEXT,            -- 볼린저 상태 (하단터치, 상한돌파 등)
    single_trade_count INT,    -- 단주거래 횟수
    is_my_stock BOOLEAN DEFAULT FALSE, -- 보유 여부
    scores INTEGER DEFAULT 0,  -- 종합 점수 (5점 만점)
    -- 각 항목별 포착 시간 (JSON으로 관리하거나 각각 컬럼 생성)
    capture_times JSONB DEFAULT '{}'::jsonb, 
    news_snippet TEXT,
    updated_at TIMESTAMP DEFAULT NOW()
);

-- [2] 이력 데이터 테이블 (10분 단위 스냅샷)
CREATE TABLE IF NOT EXISTS signal_history (
    id SERIAL PRIMARY KEY,
    symbol TEXT,
    price NUMERIC,
    scores INTEGER,
    indicators JSONB,          -- 당시의 모든 지표 상태 저장
    created_at TIMESTAMP DEFAULT NOW()
);

-- [3] 내 포트폴리오 (수동 입력 및 통합 관리)
CREATE TABLE IF NOT EXISTS my_portfolio (
    symbol TEXT PRIMARY KEY,
    stock_name TEXT,
    quantity INT DEFAULT 0,
    avg_price NUMERIC DEFAULT 0,
    brokerage TEXT,            -- 증권사 (키움, 한투 등)
    updated_at TIMESTAMP DEFAULT NOW()
);
